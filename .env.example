# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for sync and seed-user auth: SUPABASE_SERVICE_ROLE_KEY=

# Development: act as this user (must match HR/Dynamics email). e.g. dwalters@dbankjm.com
# SEED_USER_EMAIL=

# Development: set to true to bypass role checks on appraisal APIs (test full workflow as one user)
# ALLOW_APPRAISAL_TEST_BYPASS=true
# When bypass is on, set this too so the UI shows "Approve as Employee" / "Approve as Manager" (and sign-off) buttons
# NEXT_PUBLIC_ALLOW_APPRAISAL_TEST_BYPASS=true

# NextAuth (Azure AD SSO) - required for session cookies and middleware
# If you see [next-auth][warn][NO_SECRET], set NEXTAUTH_SECRET (see below).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
# Generate a secret: openssl rand -base64 32
# Azure AD app registration (redirect URI: NEXTAUTH_URL/api/auth/callback/azure-ad)
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# Dynamics 365 / Dataverse (sync and HRMIS)
# DYNAMICS_TENANT_ID=
# DYNAMICS_CLIENT_ID=
# DYNAMICS_CLIENT_SECRET=
# DYNAMICS_DATAVERSE_URL=   (e.g. https://org.crm.dynamics.com)
# Optional: DYNAMICS_EMPLOYEE_ENTITY=systemusers
# Optional custom field names: DYNAMICS_FIELD_GRADE=, DYNAMICS_FIELD_DIVISION_ID=, etc.
